{
  "search_backend": {
    "type": "string",
    "label": "搜索后端",
    "default": "bing",
    "description": "bing = 爬 cn.bing.com（国内直连，默认）；duckduckgo = ddgs 库；searxng = 自托管"
  },
  "searxng_url": {
    "type": "string",
    "label": "SearXNG 地址（searxng 后端时生效）",
    "default": "http://localhost:8080",
    "description": "SearXNG 实例 URL"
  },
  "proxy": {
    "type": "string",
    "label": "代理地址",
    "default": "",
    "description": "HTTP/HTTPS 代理，如 http://127.0.0.1:7890。Bing 后端默认不需要"
  },
  "max_results": {
    "type": "int",
    "label": "搜索结果数",
    "default": 5,
    "description": "1-20，建议 5 以内避免 LLM 原文照搬"
  },
  "cache_ttl": {
    "type": "int",
    "label": "缓存有效期（秒）",
    "default": 900,
    "description": "设 0 禁用缓存"
  },
  "cache_max_size": {
    "type": "int",
    "label": "缓存最大条目",
    "default": 100,
    "description": "超出淘汰最旧条目"
  },
  "fetch_timeout": {
    "type": "int",
    "label": "页面超时（秒）",
    "default": 15
  },
  "fetch_max_chars": {
    "type": "int",
    "label": "页面截取长度",
    "default": 10000
  },
  "enable_prompt_hint": {
    "type": "bool",
    "label": "注入系统提示词",
    "default": true
  }
}
